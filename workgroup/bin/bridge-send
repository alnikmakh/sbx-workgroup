#!/bin/sh
# bridge-send --to <agent> --kind <plan|report|note> --file <path> [--subject <text>]
set -eu
: "${BRIDGE_DIR:?BRIDGE_DIR not set}"
: "${AGENT_ID:?AGENT_ID not set}"
_p=$0
while [ -L "$_p" ]; do _d=$(cd "$(dirname "$_p")" && pwd -P); _l=$(readlink "$_p"); case $_l in /*) _p=$_l ;; *) _p="$_d/$_l" ;; esac; done
HERE=$(cd "$(dirname "$_p")" && pwd -P)
. "$HERE/../lib/bridge.sh"

TO="" KIND="" FILE="" SUBJECT=""
while [ $# -gt 0 ]; do
  case $1 in
    --to)      TO=$2; shift 2;;
    --kind)    KIND=$2; shift 2;;
    --file)    FILE=$2; shift 2;;
    --subject) SUBJECT=$2; shift 2;;
    *) echo "unknown arg: $1" >&2; exit 2;;
  esac
done
[ -n "$TO" ]   || { echo "missing --to"   >&2; exit 2; }
[ -n "$KIND" ] || { echo "missing --kind" >&2; exit 2; }
[ -n "$FILE" ] || { echo "missing --file" >&2; exit 2; }
[ -f "$FILE" ] || { echo "file not found: $FILE" >&2; exit 2; }

case $KIND in plan|report|note) ;;
  *) echo "bad kind: $KIND (expected plan|report|note)" >&2; exit 2;;
esac

if ! bridge_topology_allows "$BRIDGE_DIR" "$AGENT_ID" "$TO"; then
  echo "no edge $AGENT_ID->$TO in $BRIDGE_DIR/state.json" >&2
  exit 3
fi

ID=$(bridge_next_signal_id "$BRIDGE_DIR" "$AGENT_ID")
KIND_DIR="${KIND}s"
PAYLOAD_REL="$KIND_DIR/$ID.md"
cp "$FILE" "$BRIDGE_DIR/$PAYLOAD_REL"

TS=$(date -u +%Y-%m-%dT%H:%M:%SZ)
SIGNAL=$(jq -n \
  --arg id "$ID" --arg from "$AGENT_ID" --arg to "$TO" \
  --arg kind "$KIND" --arg payload "$PAYLOAD_REL" \
  --arg subject "$SUBJECT" --arg ts "$TS" \
  '{id:$id, from:$from, to:$to, kind:$kind, payload:$payload,
    subject:$subject, created_at:$ts}')

printf '%s\n' "$SIGNAL" | bridge_atomic_write "$BRIDGE_DIR/inbox/$TO/$ID.json"
printf '%s\n' "$SIGNAL" | bridge_atomic_write "$BRIDGE_DIR/outbox/$AGENT_ID/$ID.json"
printf '%s\n' "$ID"
