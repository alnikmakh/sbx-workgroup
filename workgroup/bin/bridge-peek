#!/bin/sh
# bridge-peek — non-destructive full listing of $AGENT_ID's inbox.
# Thin wrapper: identical to `bridge-recv` with no filters or --pop.
set -eu
_p=$0
while [ -L "$_p" ]; do _d=$(cd "$(dirname "$_p")" && pwd -P); _l=$(readlink "$_p"); case $_l in /*) _p=$_l ;; *) _p="$_d/$_l" ;; esac; done
HERE=$(cd "$(dirname "$_p")" && pwd -P)
exec "$HERE/bridge-recv"
