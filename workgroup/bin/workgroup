#!/bin/sh
# Standalone workgroup dispatcher. POSIX sh. Sources lib/{config,manifest,
# worktree,tmux,bridge}.sh.
set -eu

# Portable symlink-resolving script-dir. POSIX `pwd -P` + manual readlink loop
# replaces GNU `readlink -f` so this works on macOS without coreutils.
_resolve_dir() {
  _p=$1
  while [ -L "$_p" ]; do
    _d=$(cd "$(dirname "$_p")" && pwd -P)
    _l=$(readlink "$_p")
    case $_l in
      /*) _p=$_l ;;
      *)  _p="$_d/$_l" ;;
    esac
  done
  cd "$(dirname "$_p")" && pwd -P
}
_here=$(_resolve_dir "$0")
_lib="$_here/../lib"
# shellcheck source=/dev/null
. "$_lib/config.sh"
# shellcheck source=/dev/null
. "$_lib/manifest.sh"
# shellcheck source=/dev/null
. "$_lib/bridge.sh"
# shellcheck source=/dev/null
. "$_lib/worktree.sh"
# shellcheck source=/dev/null
. "$_lib/tmux.sh"

# WORKGROUP_ROOT = the CLI payload root (parent of bin/, lib/, templates/).
# Resolved from the script's own location so a clone-and-run install works.
: "${WORKGROUP_ROOT:=$(cd "$_here/.." && pwd -P)}"

# Load config + apply XDG defaults for $BRIDGE_ROOT, $WORKTREE_ROOT,
# $WORKGROUP_HOME, optional $WORKGROUP_PROJECTS_ROOT, $WORKGROUP_MCP_BLOCK.
# Tests that pre-set BRIDGE_ROOT/WORKTREE_ROOT keep working — config_load uses
# `:${var:=…}` so existing values win.
config_load

die() { echo "workgroup: $*" >&2; exit 1; }

usage() {
  cat <<'EOF'
usage: workgroup <command> [args]

  up <file.yaml> [--worktree PATH] [--no-worktree] [--source PATH]
  down <name> [--force]
  ls
  attach <name>
  status <name>
  logs <name> <agent>
  doctor
EOF
}

cmd_up() {
  _file='' _wt_mode=default _wt_path='' _src=''
  while [ $# -gt 0 ]; do
    case $1 in
      --worktree) _wt_mode=explicit; _wt_path=${2:-}; shift 2 ;;
      --no-worktree) _wt_mode=none; shift ;;
      --source) _src=${2:-}; shift 2 ;;
      -h|--help) usage; return 0 ;;
      -*) die "up: unknown flag $1" ;;
      *) [ -z "$_file" ] && _file=$1 || die "up: extra arg $1"; shift ;;
    esac
  done
  [ -n "$_file" ] || die "up: manifest file required"

  manifest_parse "$_file" || exit 1
  manifest_validate "$_file" "$WORKGROUP_ROOT/templates" || exit 1

  tmux_session_exists "$WG_NAME" \
    && die "session '$WG_NAME' already exists — attach with 'workgroup attach $WG_NAME' or remove with 'workgroup down $WG_NAME'"

  # Resolve WORK_ROOT (the source repo the worktree is forked from).
  # Order: --source flag → manifest's worktree.source → existing $WORK_ROOT
  # (tests, sbx mode) → manifest dir if it's inside a git repo → cwd if
  # it's a git repo → $WORKGROUP_PROJECTS_ROOT/<name>.
  if [ -n "$_src" ]; then
    WORK_ROOT=$_src
  elif [ -n "${WG_SOURCE:-}" ]; then
    WORK_ROOT=$WG_SOURCE
  elif [ -n "${WORK_ROOT:-}" ]; then
    : # already set (tests, sbx postinstall)
  else
    _mdir=$(cd "$(dirname "$_file")" && pwd -P)
    if git -C "$_mdir" rev-parse --show-toplevel >/dev/null 2>&1; then
      WORK_ROOT=$(git -C "$_mdir" rev-parse --show-toplevel)
    elif git -C "$PWD" rev-parse --show-toplevel >/dev/null 2>&1; then
      WORK_ROOT=$(git -C "$PWD" rev-parse --show-toplevel)
    elif [ -n "${WORKGROUP_PROJECTS_ROOT:-}" ] && [ -d "$WORKGROUP_PROJECTS_ROOT/$WG_NAME" ]; then
      WORK_ROOT="$WORKGROUP_PROJECTS_ROOT/$WG_NAME"
    else
      die "up: could not resolve source repo — pass --source PATH, set worktree.source in the manifest, or run inside a git checkout"
    fi
  fi
  export WORK_ROOT
  # Reset WORKTREE_ROOT default *after* WORK_ROOT is known if config didn't
  # supply one. config_load may have left it unset when neither env nor config
  # provided a value AND we're outside the sbx VM.
  : "${WORKTREE_ROOT:=$WORKGROUP_HOME/worktrees}"
  export WORKTREE_ROOT

  _wt=$(worktree_resolve "$WG_NAME" "$_wt_mode" "$WG_BRANCH" "$WG_BASE" "$_wt_path") || exit 1

  # Initialize the bridge namespace via Phase 03 helper.
  bridge_init "$WG_NAME" "$WG_AGENTS" "$WG_EDGES" || die "bridge_init failed"
  _bd=$(bridge_path "$WG_NAME")

  # Populate state.json fields the dispatcher owns.
  _state="$_bd/state.json"
  _state_branch=$WG_BRANCH _state_wt=$_wt _state_path=$_state
  _update_state_body() {
    _tmp="$_state_path.new.$$"
    jq --arg wt "$_state_wt" --arg br "$_state_branch" \
       '.worktree=$wt | .branch=$br' "$_state_path" > "$_tmp"
    mv "$_tmp" "$_state_path"
  }
  locked_subshell "$_state.lock" _update_state_body

  # Optional MCP server registration. Reads $WORKGROUP_MCP_BLOCK (set by
  # config_load from config.yaml's `mcp:` list, TSV: name<TAB>transport<TAB>url).
  # Failures are warnings, not fatal — the workgroup is still useful without
  # the index. Skipped silently if claude is not on PATH (test stubs etc).
  if [ -n "${WORKGROUP_MCP_BLOCK:-}" ] && command -v claude >/dev/null 2>&1; then
    printf '%s\n' "$WORKGROUP_MCP_BLOCK" | while IFS='	' read -r _mn _mt _mu; do
      [ -n "$_mn" ] && [ -n "$_mu" ] || continue
      claude mcp add --transport "${_mt:-http}" --scope user "$_mn" "$_mu" \
        >/dev/null 2>&1 \
        || printf 'workgroup: warning: failed to register MCP server %s (%s)\n' "$_mn" "$_mu" >&2
    done
  fi

  # Copy role briefings into the bridge.
  _old=${IFS- }; IFS=','
  for _a in $WG_AGENTS; do
    _src=$(manifest_role_file_for "$_a")
    cp "$_src" "$_bd/roles/$_a.md"
  done
  IFS=$_old

  # Build tmux session + launch panes.
  # shellcheck disable=SC2086
  tmux_create_session "$WG_NAME" "$WG_LAYOUT" "$_bd" $(printf '%s' "$WG_AGENTS" | tr ',' ' ') \
    || die "tmux create failed"
  tmux_add_watch_window "$WG_NAME" "$WG_NAME" || die "watch window failed"

  _old=${IFS- }; IFS=','
  for _a in $WG_AGENTS; do
    _out=$(manifest_peers_out "$_a")
    _in=$(manifest_peers_in "$_a")
    tmux_send_launch "$WG_NAME" "$_a" "$_wt" "$_bd" "$_out" "$_in" "$_bd/roles/$_a.md"
  done
  IFS=$_old

  printf 'Workgroup "%s" up. Attach with: workgroup attach %s\n' "$WG_NAME" "$WG_NAME"
  printf '  worktree: %s\n  branch:   %s\n  agents:   %s\n  edges:    %s\n' \
    "$_wt" "$WG_BRANCH" "$WG_AGENTS" "$WG_EDGES"
}

cmd_down() {
  _name='' _force=0
  while [ $# -gt 0 ]; do
    case $1 in
      --force) _force=1; shift ;;
      -*) die "down: unknown flag $1" ;;
      *) [ -z "$_name" ] && _name=$1 || die "down: extra arg $1"; shift ;;
    esac
  done
  [ -n "$_name" ] || die "down: name required"

  tmux_kill_session "$_name"

  _bd="$BRIDGE_ROOT/$_name"
  # Read the authoritative worktree path from state.json BEFORE archiving,
  # otherwise we lose the handle in the mv below. Falls back to the legacy
  # computed path only if state.json is missing.
  _wt=""
  if [ -f "$_bd/state.json" ]; then
    _wt=$(jq -r '.worktree // ""' "$_bd/state.json")
  fi
  [ -n "$_wt" ] || _wt="${WORKTREE_ROOT:-$WORK_ROOT/worktrees}/$_name"

  if [ -d "$_bd" ]; then
    # /bridge/_archive/<name>-<ts>/.
    # Invariant: manifest name regex requires [a-z0-9] as the first char, so
    # no workgroup can ever be named "_archive" and shadow this dir. Do NOT
    # relax the regex without also moving the archive root.
    mkdir -p "$BRIDGE_ROOT/_archive"
    _ts=$(date -u +%Y%m%dT%H%M%SZ)
    mv "$_bd" "$BRIDGE_ROOT/_archive/$_name-$_ts"
  fi

  if [ "$_force" = 1 ]; then
    if [ -d "$_wt" ]; then
      # --force means "really nuke it" — agents always leave scratch files
      # like .tmp/ behind, so refusing on a dirty worktree would force the
      # user to rm -rf manually before every down. Bypass the clean check
      # and call `git worktree remove --force` directly.
      if git -C "$_wt" rev-parse --is-inside-work-tree >/dev/null 2>&1; then
        git -C "$_wt" worktree remove --force "$_wt" >&2 \
          && printf 'removed worktree: %s\n' "$_wt" \
          || die "failed to remove worktree $_wt"
      else
        die "$_wt is not a git worktree"
      fi
    fi
  fi

  printf 'Workgroup "%s" down.\n' "$_name"
}

cmd_ls() {
  printf '%-20s %-8s %-8s %s\n' NAME STATUS AGENTS WORKTREE
  # Active = tmux sessions.
  tmux ls -F '#{session_name}' 2>/dev/null | while read -r _s; do
    [ -n "$_s" ] || continue
    _st="$BRIDGE_ROOT/$_s/state.json"
    if [ -f "$_st" ]; then
      _ac=$(jq -r '.agents | length' "$_st")
      _wt=$(jq -r '.worktree // ""' "$_st")
    else
      _ac='?'; _wt='?'
    fi
    printf '%-20s %-8s %-8s %s\n' "$_s" running "$_ac" "$_wt"
  done
  if [ -d "$BRIDGE_ROOT/_archive" ]; then
    for _d in "$BRIDGE_ROOT/_archive"/*/; do
      [ -d "$_d" ] || continue
      _b=$(basename "$_d")
      printf '%-20s %-8s %-8s %s\n' "$_b" archived '-' '-'
    done
  fi
}

cmd_attach() {
  [ $# -eq 1 ] || die "attach: exactly one name required"
  tmux_session_exists "$1" || die "no such session: $1"
  exec tmux attach -t "=$1"
}

cmd_status() {
  [ $# -eq 1 ] || die "status: exactly one name required"
  _name=$1
  _st="$BRIDGE_ROOT/$_name/state.json"
  [ -f "$_st" ] || die "no bridge for '$_name'"
  printf '%-12s %-8s %s\n' agent inbox last-activity
  _ids=$(jq -r '.agents[].id' "$_st")
  # Pane activity map (may be empty if session gone).
  _pa=$(tmux list-panes -t "=$_name:agents" -F '#{pane_title} #{t:pane_activity}' 2>/dev/null || true)
  _now=$(date +%s)
  printf '%s\n' "$_ids" | while read -r _a; do
    [ -n "$_a" ] || continue
    _count=$(find "$BRIDGE_ROOT/$_name/inbox/$_a" -maxdepth 1 -name '*.json' 2>/dev/null | wc -l)
    _ts=$(printf '%s\n' "$_pa" | awk -v a="$_a" '$1==a {print $2; exit}')
    if [ -n "$_ts" ]; then
      _age=$(( _now - _ts ))
      _la="${_age}s ago"
    else
      _la='-'
    fi
    printf '%-12s %-8s %s\n' "$_a" "$_count" "$_la"
  done
}

cmd_doctor() {
  _bad=0
  printf 'workgroup doctor\n'
  printf '  WORKGROUP_ROOT       %s\n' "$WORKGROUP_ROOT"
  printf '  WORKGROUP_HOME       %s\n' "$WORKGROUP_HOME"
  printf '  BRIDGE_ROOT          %s\n' "$BRIDGE_ROOT"
  printf '  WORKTREE_ROOT        %s\n' "$WORKTREE_ROOT"
  printf '  WORKGROUP_CONFIG     %s%s\n' "$WORKGROUP_CONFIG" \
    "$( [ -f "$WORKGROUP_CONFIG" ] && printf ' (present)' || printf ' (absent, using defaults)' )"
  printf '\ndependencies:\n'
  for _d in tmux git jq yq claude; do
    if command -v "$_d" >/dev/null 2>&1; then
      printf '  %-8s OK   %s\n' "$_d" "$(command -v "$_d")"
    else
      case $_d in
        claude) printf '  %-8s MISS (optional — needed only to launch agent panes)\n' "$_d" ;;
        *)      printf '  %-8s MISS\n' "$_d"; _bad=1 ;;
      esac
    fi
  done
  if command -v flock >/dev/null 2>&1; then
    printf '  flock    OK   %s\n' "$(command -v flock)"
  else
    printf '  flock    MISS (using mkdir-lock fallback — fine on macOS)\n'
  fi
  if command -v inotifywait >/dev/null 2>&1; then
    printf '  inotifywait OK (watch window will work)\n'
  else
    printf '  inotifywait MISS (watch window unavailable — install inotify-tools or fswatch wrapper)\n'
  fi
  # yq flavor sniff: Mike Farah's Go yq prints "yq (https://github.com/mikefarah/yq/)" with --version.
  if command -v yq >/dev/null 2>&1; then
    if yq --version 2>&1 | grep -q mikefarah; then
      printf '\nyq flavor: go-yq (mikefarah) — correct\n'
    else
      printf '\nyq flavor: NOT mikefarah/yq — install go-yq (brew install yq)\n'
      _bad=1
    fi
  fi
  printf '\n%s\n' "$( [ "$_bad" -eq 0 ] && printf 'all required dependencies present' || printf 'missing required dependencies above' )"
  return "$_bad"
}

cmd_logs() {
  [ $# -eq 2 ] || die "logs: <name> <agent> required"
  _name=$1 _ag=$2
  tmux_session_exists "$_name" || die "no such session: $_name"
  _bd=$(bridge_path "$_name")
  _pid=$(tmux_pane_id_for_agent "$_bd" "$_ag")
  [ -n "$_pid" ] || die "no pane for agent '$_ag' in session '$_name'"
  tmux capture-pane -t "$_pid" -p -S -3000
}

main() {
  [ $# -ge 1 ] || { usage; exit 1; }
  _sub=$1; shift
  case $_sub in
    up)     cmd_up     "$@" ;;
    down)   cmd_down   "$@" ;;
    ls)     cmd_ls     "$@" ;;
    attach) cmd_attach "$@" ;;
    status) cmd_status "$@" ;;
    logs)   cmd_logs   "$@" ;;
    doctor) cmd_doctor "$@" ;;
    -h|--help|help) usage ;;
    *) die "unknown subcommand: $_sub" ;;
  esac
}

main "$@"
